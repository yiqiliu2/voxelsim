THERMAL_JOBS=${THERMAL_JOBS:-4}
THERMAL_CORES_PER_JOB=${THERMAL_CORES_PER_JOB:-32}
TRACE_JOBS=${TRACE_JOBS:-5}

COOLING_PROFILE=${COOLING_PROFILE:-sxm_air}
AMBIENT_C=${AMBIENT_C:-35}
BOND_THICKNESS_UM=${BOND_THICKNESS_UM:-10}
HOTSPOT_GRID=${HOTSPOT_GRID:-128}
DRAM_LAYERS=${DRAM_LAYERS:-8}
NOC_POWER_BACKEND=${NOC_POWER_BACKEND:-dsent}
NOC_POWER_FLIT_BITS=${NOC_POWER_FLIT_BITS:-256}
