# Shared paths/settings for thermal reproduction.

MPLCONFIGDIR=${MPLCONFIGDIR:-/tmp/3dstack-mpl}

TRACE_ROOT=${TRACE_ROOT:-results/logs_matrix_bs1_seq2048_paper_sa}
PREFILL_PICKLE_ROOT=${PREFILL_PICKLE_ROOT:-results/pickles/outputs_icbm_2048_training_matrix_bs1_paper_sa}
DECODE_PICKLE_ROOT=${DECODE_PICKLE_ROOT:-results/pickles/outputs_icbm_2048_matrix_decode_bs32_paper_sa}
THERMAL_ROOT=${THERMAL_ROOT:-results/thermal_matrix_prefill_bs1_seq2048_decode_bs32_iter100_tsim_area}

CORE_COUNT=${CORE_COUNT:-256}
CORE_MEM_KB=${CORE_MEM_KB:-2048}
HW_JSON=${HW_JSON:-sa_32_vu_32_drambw_12288_noc_1_32}
CORE_GROUP=${CORE_GROUP:-8}
ROW=${ROW:-8192}
DRAM_BW=${DRAM_BW:-12288}
DRAM_NAME=${DRAM_NAME:-PLACEHOLDER}

PREFILL_BATCH=${PREFILL_BATCH:-1}
PREFILL_SEQ=${PREFILL_SEQ:-2048}
DECODE_BATCH=${DECODE_BATCH:-32}
DECODE_ISL=${DECODE_ISL:-2048}
